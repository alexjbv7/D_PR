# quant_bot environment template — copy to .env (gitignored) and fill in.
# DO NOT commit .env.

# --- Notificaciones ---
# Discord webhook URL para daily briefing, weekly review, drills.
# Crear en Discord: Canal → Editar → Integraciones → Webhooks → Nuevo Webhook.
DISCORD_WEBHOOK_URL=

# Slack webhook (alternativa / coexistencia). Vacío = deshabilitado.
SLACK_WEBHOOK=

# --- Alpaca paper ---
ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_BASE_URL=https://paper-api.alpaca.markets
ALPACA_PAPER=true
