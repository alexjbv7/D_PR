{
  "annotations": { "list": [] },
  "description": "Drift Detection & ECE Monitoring — Semana 8 (PSI, ECE, retrain triggers)",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "datasource": { "type": "postgres", "uid": "${DS_TIMESCALEDB}" },
      "description": "PSI per feature × day (last 30d). Yellow ≥0.10, red ≥0.25.",
      "fieldConfig": {
        "defaults": {
          "custom": { "hideFrom": { "tooltip": false, "viz": false, "legend": false } },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.1 },
              { "color": "red", "value": 0.25 }
            ]
          }
        },
        "overrides": []
      },
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 0 },
      "id": 1,
      "options": {
        "calculate": false,
        "cellGap": 1,
        "color": { "exponent": 0.5, "fill": "dark-orange", "mode": "scheme", "scheme": "RdYlGn", "reverse": true },
        "exemplars": { "color": "rgba(255,0,255,0.7)" },
        "filterValues": { "le": 1e-9 },
        "legend": { "show": true },
        "rowsFrame": { "layout": "auto" },
        "tooltip": { "show": true, "yHistogram": false },
        "yAxis": { "axisPlacement": "left", "reverse": false }
      },
      "pluginVersion": "10.0.0",
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${DS_TIMESCALEDB}" },
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  time_bucket('1 day', ts) AS time,\n  feature_name,\n  MAX(psi) AS psi\nFROM drift.psi_history\nWHERE ts >= NOW() - INTERVAL '30 days'\n  AND horizon = '$horizon'\nGROUP BY 1, 2\nORDER BY 1;",
          "refId": "A"
        }
      ],
      "title": "PSI Heatmap — per feature (30d)",
      "transformations": [
        {
          "id": "rowsToFields",
          "options": { "mappings": [] }
        },
        {
          "id": "prepareTimeSeries",
          "options": { "format": "wide" }
        }
      ],
      "type": "heatmap"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Rolling ECE per horizon. Dashed threshold at 0.05.",
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2, "spanNulls": false },
          "color": { "mode": "palette-classic" },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "red", "value": 0.05 }
            ]
          },
          "unit": "none",
          "max": 0.2,
          "min": 0
        },
        "overrides": []
      },
      "gridPos": { "h": 10, "w": 12, "x": 12, "y": 0 },
      "id": 2,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "drift_ece_value",
          "legendFormat": "{{horizon}}",
          "refId": "A"
        }
      ],
      "title": "ECE Rolling (Prometheus gauge)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "description": "Drift events by severity (rate per day).",
      "fieldConfig": {
        "defaults": {
          "custom": { "fillOpacity": 80, "stacking": { "mode": "normal", "group": "A" } },
          "color": { "mode": "palette-classic" }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "moderate" },
            "properties": [{ "id": "color", "value": { "fixedColor": "yellow", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "severe" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 10 },
      "id": 3,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
          "expr": "sum by (severity) (increase(drift_events_total{horizon=\"$horizon\"}[1d]))",
          "legendFormat": "{{severity}}",
          "refId": "A"
        }
      ],
      "title": "Drift Events / day (moderate vs severe)",
      "type": "barchart"
    },
    {
      "datasource": { "type": "postgres", "uid": "${DS_TIMESCALEDB}" },
      "description": "Retrain triggers vs macro-suppressed (from drift.retrain_history).",
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 2, "fillOpacity": 15 },
          "color": { "mode": "palette-classic" }
        },
        "overrides": [
          {
            "matcher": { "id": "byName", "options": "triggered" },
            "properties": [{ "id": "color", "value": { "fixedColor": "red", "mode": "fixed" } }]
          },
          {
            "matcher": { "id": "byName", "options": "suppressed" },
            "properties": [{ "id": "color", "value": { "fixedColor": "orange", "mode": "fixed" } }]
          }
        ]
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 10 },
      "id": 4,
      "options": {
        "legend": { "displayMode": "list", "placement": "bottom" },
        "tooltip": { "mode": "multi" }
      },
      "targets": [
        {
          "datasource": { "type": "postgres", "uid": "${DS_TIMESCALEDB}" },
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT\n  time_bucket('1 day', ts) AS time,\n  SUM(CASE WHEN suppressed THEN 1 ELSE 0 END) AS suppressed,\n  SUM(CASE WHEN NOT suppressed THEN 1 ELSE 0 END) AS triggered\nFROM drift.retrain_history\nWHERE ts >= NOW() - INTERVAL '30 days'\n  AND horizon = '$horizon'\nGROUP BY 1\nORDER BY 1;",
          "refId": "A"
        }
      ],
      "title": "Retrain Triggers vs Macro Suppressions",
      "type": "timeseries"
    }
  ],
  "refresh": "5m",
  "schemaVersion": 38,
  "tags": ["ml", "drift", "monitoring", "semana-8"],
  "templating": {
    "list": [
      {
        "current": { "text": "prometheus", "value": "prometheus" },
        "hide": 0,
        "includeAll": false,
        "label": "Prometheus",
        "name": "DS_PROMETHEUS",
        "options": [],
        "query": "prometheus",
        "refresh": 1,
        "type": "datasource"
      },
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "label": "TimescaleDB",
        "name": "DS_TIMESCALEDB",
        "options": [],
        "query": "postgres",
        "refresh": 1,
        "type": "datasource"
      },
      {
        "current": { "text": "swing", "value": "swing" },
        "hide": 0,
        "includeAll": false,
        "label": "Horizon",
        "name": "horizon",
        "options": [
          { "text": "intraday", "value": "intraday" },
          { "text": "swing", "value": "swing" },
          { "text": "daily", "value": "daily" }
        ],
        "query": "intraday,swing,daily",
        "type": "custom"
      }
    ]
  },
  "time": { "from": "now-30d", "to": "now" },
  "timepicker": {},
  "timezone": "utc",
  "title": "Drift Monitor — S8",
  "uid": "drift-monitor-s8",
  "version": 2
}
